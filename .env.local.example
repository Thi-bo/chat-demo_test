# ============================================================
# Mode LOCAL avec proxy (auth web / cookies)
# ============================================================
# Copier en .env et lancer :
#   - Backend : php artisan serve --port=8000
#   - Reverb  : php artisan reverb:start --port=8081
#   - Queue   : php artisan queue:work
#   - Front   : npm run dev
# Les requêtes /api et /broadcasting partent vers localhost:5173
# et Vite les proxy vers le backend (8000).
# ============================================================

# Vide = requêtes relatives → proxy Vite vers http://127.0.0.1:8000
VITE_API_URL=

# Reverb local (même clés que le .env du backend)
VITE_REVERB_APP_KEY=pwusg2upa4ou910by6py
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME=http
